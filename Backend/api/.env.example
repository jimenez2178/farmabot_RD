PORT=3000

# Token que tú inventas y pones también en la configuración del webhook en Meta
WHATSAPP_VERIFY_TOKEN=

# Token de acceso de la app de Meta (WhatsApp Cloud API)
WHATSAPP_ACCESS_TOKEN=

# Phone Number ID del número de WhatsApp Business
WHATSAPP_PHONE_NUMBER_ID=

# WhatsApp Business Account ID (para suscribir el webhook al campo "messages")
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Versión de la Graph API de Meta
WHATSAPP_API_VERSION=v21.0

# API key de Anthropic (console.anthropic.com) para las respuestas con Claude Haiku
ANTHROPIC_API_KEY=

# Nombre de la farmacia, para personalizar el system prompt de Claude (temporal hasta tener multi-tenant real vía DB)
PHARMACY_NAME=

# Supabase (console.supabase.com) — URL del proyecto y Service Role Key (bypasea RLS, solo uso en backend)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# API key interna para proteger endpoints manuales/admin (ej. POST /api/recordatorios/enviar-ahora)
INTERNAL_API_KEY=
